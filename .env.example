# Supabase - copy from your project's API settings
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Never add the service_role key here. It bypasses RLS and must stay server-side only.

# Optional for authenticated Playwright E2E runs.
# Points to a storageState JSON generated from an allowed Supabase test user.
E2E_AUTH_STORAGE_STATE=

# Optional for MCP integrations.
# SUPABASE_ACCESS_TOKEN is used by the official Supabase MCP server.
# GTI_MCP_USER_ACCESS_TOKEN is used by the GTI domain MCP acting as an authenticated user.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_ACCESS_TOKEN=
GTI_MCP_USER_ACCESS_TOKEN=
